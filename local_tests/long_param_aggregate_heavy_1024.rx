struct Pair {
    x: usize,
    y: i32,
    flag: bool,
}

struct RefPack {
    a: &usize,
    b: &mut usize,
    flags: [bool; 3],
}

struct Agg {
    pair: Pair,
    arr: [usize; 3],
    pairs: [Pair; 2],
    refs: RefPack,
    matrix: [[usize; 2]; 2],
}

