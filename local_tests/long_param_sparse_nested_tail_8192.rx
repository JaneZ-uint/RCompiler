struct Pair {
    x: usize,
    y: i32,
    ok: bool,
}

fn id(x: usize) -> usize { return x; }
fn make_usize(seed: usize) -> usize { return 4294967296usize + 8000usize + seed; }
fn make_i32(seed: usize) -> i32 { return (seed as i32) % 1000 - 500; }
fn make_bool(seed: usize) -> bool { return seed % 2usize == 0usize; }
fn make_pair(seed: usize, y: i32, ok: bool) -> Pair { return Pair { x: 4294967296usize + 1000usize + seed, y: y, ok: ok }; }
fn make_arr(seed: usize) -> [usize; 3] { return [4294967296usize + 3000usize + seed, 4294967296usize + 4000usize + seed, 4294967296usize + 5000usize + seed]; }

