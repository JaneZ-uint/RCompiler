fn add_usize(x: usize, y: usize) -> usize {
    return x + y + 17usize;
}

fn add_isize(x: isize, y: isize) -> isize {
    return x + y - 9isize;
}

fn mix_i32(x: i32, y: i32) -> i32 {
    return x * 3 + y - 5;
}

fn mix_u32(x: u32, y: u32) -> u32 {
    return x + y * 2u32 + 23u32;
}

fn ok_mix(x: usize, y: i32) -> bool {
    return (x % 5usize == 0usize) || (y % 7 == 3);
}

