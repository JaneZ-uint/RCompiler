struct Pair {
    x: usize,
    y: bool,
}

struct Ret {
    score: usize,
    pair_x: usize,
    arr_v: usize,
    flag: bool,
}

fn leaf(
    a0: i32,
    a1: usize,
    a2: u32,
    a3: bool,
    a4: isize,
    a5: i32,
    a6: bool,
    a7: usize,
    p0: & &mut usize,
    p1: & &mut i32,
    p2: & &mut u32,
    p3: & &mut bool,
    p4: & &mut Pair,
    p5: & &mut [usize; 3],
    q0: &mut &mut usize,
    q1: &mut &mut i32,
    q2: &mut &mut u32,
    q3: &mut &mut bool,
    q4: &mut &mut Pair,
    q5: &mut &mut [usize; 3],
    tail0: usize,
    tail1: & &mut usize
) -> Ret {
    let mut score: usize = 0usize;
    if (a0 == -1) { score += 1usize; }
    if (a1 == 4294967296usize + 2usize) { score += 2usize; }
    if (a2 == 2147483655u32) { score += 4usize; }
    if (a3 == true) { score += 8usize; }
    if (a4 == -5isize) { score += 16usize; }
    if (a5 == 6) { score += 32usize; }
    if (a6 == false) { score += 64usize; }
    if (a7 == 4294967296usize + 7usize) { score += 128usize; }

    **p0 += 11usize;
    **p1 += 13;
    **p2 += 17u32;
    **p3 = false;
    (**p4).x += 19usize;
    (**p4).y = false;
    (**p5)[2] += 23usize;
    if (**p0 == 4294967296usize + 111usize) { score += 3usize; }
    if (**p1 == 33) { score += 5usize; }
    if (**p2 == 2147483717u32) { score += 7usize; }
    if (**p3 == false) { score += 11usize; }
    if ((**p4).x == 4294967296usize + 219usize) { score += 13usize; }
    if ((**p5)[2] == 4294967296usize + 323usize) { score += 17usize; }

    **q0 += 29usize;
    **q1 += 31;
    **q2 += 37u32;
    **q3 = true;
    (**q4).x += 41usize;
    (**q4).y = false;
    (**q5)[1] += 43usize;
    if (**q0 == 4294967296usize + 529usize) { score += 19usize; }
    if (**q1 == 71) { score += 23usize; }
    if (**q2 == 2147483837u32) { score += 29usize; }
    if (**q3 == true) { score += 31usize; }
    if ((**q4).x == 4294967296usize + 641usize) { score += 37usize; }
    if ((**q5)[1] == 4294967296usize + 743usize) { score += 41usize; }

    if (tail0 == 4294967296usize + 900usize) { score += 43usize; }
    **tail1 += 47usize;
    if (**tail1 == 4294967296usize + 947usize) { score += 47usize; }

    return Ret {
        score: score,
        pair_x: (**q4).x,
        arr_v: (**q5)[1],
        flag: **q3,
    };
}

fn middle(
    b0: i32,
    b1: usize,
    b2: u32,
    b3: bool,
    b4: isize,
    b5: i32,
    b6: bool,
    b7: usize,
    p0: & &mut usize,
    p1: & &mut i32,
    p2: & &mut u32,
    p3: & &mut bool,
    p4: & &mut Pair,
    p5: & &mut [usize; 3],
    q0: &mut &mut usize,
    q1: &mut &mut i32,
    q2: &mut &mut u32,
    q3: &mut &mut bool,
    q4: &mut &mut Pair,
    q5: &mut &mut [usize; 3],
    tail0: usize,
    tail1: & &mut usize
) -> Ret {
    return leaf(
        b0, b1, b2, b3, b4, b5, b6, b7,
        p0, p1, p2, p3, p4, p5,
        q0, q1, q2, q3, q4, q5,
        tail0, tail1
    );
}

fn main() {
    let mut u0: usize = 4294967296usize + 100usize;
    let mut ru0: &mut usize = &mut u0;
    let mut i0: i32 = 20;
    let mut ri0: &mut i32 = &mut i0;
    let mut n0: u32 = 2147483700u32;
    let mut rn0: &mut u32 = &mut n0;
    let mut b0: bool = true;
    let mut rb0: &mut bool = &mut b0;
    let mut p0v: Pair = Pair { x: 4294967296usize + 200usize, y: true };
    let mut rp0v: &mut Pair = &mut p0v;
    let mut a0v: [usize; 3] = [1usize, 2usize, 4294967296usize + 300usize];
    let mut ra0v: &mut [usize; 3] = &mut a0v;

    let mut u1: usize = 4294967296usize + 500usize;
    let mut ru1: &mut usize = &mut u1;
    let mut i1: i32 = 40;
    let mut ri1: &mut i32 = &mut i1;
    let mut n1: u32 = 2147483800u32;
    let mut rn1: &mut u32 = &mut n1;
    let mut b1: bool = false;
    let mut rb1: &mut bool = &mut b1;
    let mut p1v: Pair = Pair { x: 4294967296usize + 600usize, y: true };
    let mut rp1v: &mut Pair = &mut p1v;
    let mut a1v: [usize; 3] = [3usize, 4294967296usize + 700usize, 4usize];
    let mut ra1v: &mut [usize; 3] = &mut a1v;

    let mut tv: usize = 4294967296usize + 900usize;
    let mut rtv: &mut usize = &mut tv;
    let ret: Ret = middle(
        -1,
        4294967296usize + 2usize,
        2147483655u32,
        true,
        -5isize,
        6,
        false,
        4294967296usize + 7usize,
        &ru0,
        &ri0,
        &rn0,
        &rb0,
        &rp0v,
        &ra0v,
        &mut ru1,
        &mut ri1,
        &mut rn1,
        &mut rb1,
        &mut rp1v,
        &mut ra1v,
        4294967296usize + 900usize,
        &rtv
    );
    printlnInt(ret.score as i32);
    printlnInt(u0 as i32);
    printlnInt(i0);
    printlnInt(n0 as i32);
    printlnInt(b0 as i32);
    printlnInt(p0v.x as i32);
    printlnInt(a0v[2] as i32);
    printlnInt(u1 as i32);
    printlnInt(i1);
    printlnInt(n1 as i32);
    printlnInt(b1 as i32);
    printlnInt(ret.pair_x as i32);
    printlnInt(ret.arr_v as i32);
    printlnInt(ret.flag as i32);
    printlnInt(tv as i32);
    exit(0);
}
