struct Pair {
    x: usize,
    y: i32,
    ok: bool,
}

fn ret_usize(seed: usize) -> usize { return 4294967296usize + 1000usize + seed; }
fn ret_isize(seed: usize) -> isize { return -4294967296isize - (seed % 1000usize) as isize; }
fn ret_u32(seed: usize) -> u32 { return 2147483000u32 + (seed % 997usize) as u32; }
fn ret_bool(seed: usize) -> bool { return seed % 2usize == 0usize; }
fn ret_pair(seed: usize) -> Pair { return Pair { x: 4294967296usize + 2000usize + seed, y: (seed as i32) % 1000 - 500, ok: seed % 2usize == 0usize }; }
fn ret_arr(seed: usize) -> [usize; 3] { return [4294967296usize + 3000usize + seed, 4294967296usize + 4000usize + seed, 4294967296usize + 5000usize + seed]; }

