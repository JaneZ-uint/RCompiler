struct Pair {
    x: usize,
    y: i32,
    flag: bool,
}

fn make_usize(x: usize) -> usize { return x + 3usize; }
fn make_i32(x: i32) -> i32 { return x - 4; }
fn make_u32(x: u32) -> u32 { return x + 7u32; }
fn make_isize(x: isize) -> isize { return x - 11isize; }

