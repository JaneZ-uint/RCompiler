const N: usize = 4;

struct Pair {
    a: i32,
    b: i32,
}

fn add(x: i32, y: i32) -> i32 {
    x + y
}

fn main() {
    let mut arr: [i32; N] = [10, 20, 30, 40];
    let mut p: Pair = Pair { a: 1, b: 2 };

    p.a = p.a + arr[1];

    if (p.a > p.b) {
        p.b = p.b + 3;
    } else {
        p.a = p.a + 4;
    }

    add(p.a, p.b);
    exit(0);
}
